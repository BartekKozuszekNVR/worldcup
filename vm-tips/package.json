  "scripts": {
    "lint": "eslint -c ./eslint.config.js \"./src*/**/*.{js,cjs,mjs,vue,ts}\"",
    "test": "echo \"No test specified\" && exit 0",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "quasar dev",
    "dev:server": "nitro dev",
    "build": "npm run build:client && npm run build:server && npm run build:copy-spa",
    "build:client": "quasar build",
    "build:server": "nitro build",
    "build:copy-spa": "node -e \"const fs=require('fs');fs.cpSync('dist/spa','.vercel/output/static',{recursive:true})\"",
    "preview": "nitro preview",
    "postinstall": "quasar prepare",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",

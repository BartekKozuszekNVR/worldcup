    "bcryptjs": "^3.0.3",
    "canvas-confetti": "^1.9.3",
    "drizzle-orm": "^0.45.1",
    "h3": "^1.15.5",
    "nanoid": "^5.1.6",
    "pinia": "^2.2.0",
    "quasar": "^2.16.0",
    "vue": "^3.5.22",
    "vue-i18n": "^11.2.8",
    "vue-router": "^4.0.0"
